# Database Configuration 

DATABASE_URL=mysql://root@127.0.0.1:3307/multi_agent_ai
JWT_SECRET=super_secret_cookie_key
VITE_APP_ID=mock_app_id

# Gemini / OpenAI API Configuration 
# Paste your Gemini API key (e.g. AQ.xxx or AIzaSyxxx) or OpenAI key below:

BUILT_IN_FORGE_API_KEY=your_api_key_here

# Base API URL. If using Gemini, keep it as:

BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai

# If you decide to use a direct OpenAI key instead of Gemini, change the URL to:
# BUILT_IN_FORGE_API_URL=https://api.openai.com
